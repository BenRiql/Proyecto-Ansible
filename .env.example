# =============================================================
# .env.example — Plantilla de variables de entorno
# =============================================================
# Copia este archivo como ".env" y completa los valores reales.
# El archivo ".env" real NUNCA se sube a git (ya está en .gitignore).
#
# Uso local:
#   export $(grep -v '^#' .env | xargs)
#   ansible routers -m ping
#
# En CI/CD (GitHub Actions), estos mismos nombres se configuran como
# "Secrets" del repositorio (Settings → Secrets and variables → Actions)
# y se inyectan automáticamente como variables de entorno en el workflow.
# =============================================================

ANSIBLE_USER=admin
ANSIBLE_PASSWORD=admin123
ANSIBLE_BECOME_PASSWORD=enable123
IPSEC_PSK=C1sc0Lab2024!
